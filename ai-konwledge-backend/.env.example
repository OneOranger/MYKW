# LLM
OPENAI_API_KEY=
OPENAI_BASE_URL=openai地址
MODEL_NAME=gpt-4o-mini
OPENAI_ENABLED=true
TEMPERATURE=0.3
WEB_FALLBACK_ENABLED=false

# Runtime
APP_ENV=local
APP_DEBUG=true
LOG_LEVEL=INFO
HOST=127.0.0.1
PORT=8000

# Retrieval / memory
TOP_K=5
RETRIEVAL_THRESHOLD=0.35
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_LOCAL_ONLY=true
EMBEDDING_LOCAL_PATH=data/models/all-MiniLM-L6-v2
CHUNK_SIZE=100
CHUNK_OVERLAP=20
VECTOR_TABLE_NAME=knowledge_chunks

# Paths (relative to project root)
DATA_DIR=data
LOG_DIR=logs
